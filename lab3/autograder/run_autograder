#!/usr/bin/env bash
# =============================================================================
# Gradescope Autograder — run_autograder
# CSCI 5708 Lab 3: DML Operation Logging
#
# For every student submission:
#   1. Locates the student's nodeModifyTable.c
#   2. Copies it into the PG source tree
#   3. Incremental compile
#   4. Fresh database + postgresql.conf with dml_lab.enable_logging = on
#   5. Runs test workloads, captures psql stderr (where INFO lines appear)
#   6. Invokes grade.py
# =============================================================================
set -uo pipefail

PG_SRC=/autograder/source/pg_src
PG_INSTALL=/autograder/source/pg_install
PG_DATA=/tmp/pg_data
RESULTS_DIR=/autograder/results
SUBMISSION_DIR=/autograder/submission
SRC_DIR=/autograder/source

export PATH="$PG_INSTALL/bin:$PATH"

mkdir -p "$RESULTS_DIR"

# ---------------------------------------------------------------------------
# Helper: write a failure result and exit
# ---------------------------------------------------------------------------
fail_with_message() {
    local msg="$1"
    local score="${2:-0}"
    python3 "$SRC_DIR/grade.py" --fail "$msg" --score "$score"
    exit 0
}

# ---------------------------------------------------------------------------
# 1. Locate student file
# ---------------------------------------------------------------------------
echo "=== [run_autograder] Locating student submission ==="

find_file() {
    local name="$1"
    local found=""
    if [ -f "$SUBMISSION_DIR/$name" ]; then
        found="$SUBMISSION_DIR/$name"
    else
        found=$(find "$SUBMISSION_DIR" -name "$name" -type f 2>/dev/null | head -1)
    fi
    echo "$found"
}

STUDENT_FILE=$(find_file "nodeModifyTable.c")

if [ -z "$STUDENT_FILE" ]; then
    fail_with_message "Could not find **nodeModifyTable.c** in your submission.

Please submit exactly one file: **nodeModifyTable.c**."
fi

echo "Found: $STUDENT_FILE"

# ---------------------------------------------------------------------------
# 2. Copy student file and compile
# ---------------------------------------------------------------------------
echo "=== [run_autograder] Compiling ==="

cp "$STUDENT_FILE" "$PG_SRC/src/backend/executor/nodeModifyTable.c"

cd "$PG_SRC"
touch "$PG_SRC/src/backend/executor/nodeModifyTable.c"

COMPILE_OUTPUT=$(make -j"$(nproc)" 2>&1) || {
    fail_with_message "**Compilation failed.**

Compiler output:
\`\`\`
${COMPILE_OUTPUT}
\`\`\`

Check your code for syntax errors."
}

INSTALL_OUTPUT=$(make install 2>&1) || {
    fail_with_message "**Installation failed.**

Output:
\`\`\`
${INSTALL_OUTPUT}
\`\`\`"
}

echo "Compilation successful."

# ---------------------------------------------------------------------------
# 3. Initialize database
# ---------------------------------------------------------------------------
echo "=== [run_autograder] Initializing database ==="
rm -rf "$PG_DATA"

if [ "$(id -u)" = "0" ]; then
    useradd -m -s /bin/bash pguser 2>/dev/null || true
    chown -R pguser:pguser "$PG_INSTALL" 2>/dev/null || true
    su - pguser -c "export PATH=$PG_INSTALL/bin:\$PATH && initdb -D $PG_DATA" > /dev/null 2>&1 || {
        fail_with_message "initdb failed. This is likely an autograder issue."
    }
    cp "$SRC_DIR/postgresql.conf" "$PG_DATA/postgresql.conf"
    sed -i 's/^lc_messages/#lc_messages/' "$PG_DATA/postgresql.conf"
    sed -i 's/^lc_monetary/#lc_monetary/' "$PG_DATA/postgresql.conf"
    sed -i 's/^lc_numeric/#lc_numeric/'   "$PG_DATA/postgresql.conf"
    sed -i 's/^lc_time/#lc_time/'         "$PG_DATA/postgresql.conf"
    chown pguser:pguser "$PG_DATA/postgresql.conf"
    PG_USER="pguser"
else
    initdb -D "$PG_DATA" > /dev/null 2>&1 || {
        fail_with_message "initdb failed."
    }
    cp "$SRC_DIR/postgresql.conf" "$PG_DATA/postgresql.conf"
    sed -i 's/^lc_messages/#lc_messages/' "$PG_DATA/postgresql.conf"
    sed -i 's/^lc_monetary/#lc_monetary/' "$PG_DATA/postgresql.conf"
    sed -i 's/^lc_numeric/#lc_numeric/'   "$PG_DATA/postgresql.conf"
    sed -i 's/^lc_time/#lc_time/'         "$PG_DATA/postgresql.conf"
    PG_USER="$(whoami)"
fi

# ---------------------------------------------------------------------------
# 4. Start server
# ---------------------------------------------------------------------------
echo "=== [run_autograder] Starting server ==="

SERVER_LOG=/tmp/pg_server.log
rm -f "$SERVER_LOG"

run_pg() {
    if [ "$(id -u)" = "0" ]; then
        chown -R pguser:pguser "$PG_DATA"
        su - pguser -c "export PATH=$PG_INSTALL/bin:\$PATH && $*"
    else
        eval "$@"
    fi
}

run_pg "pg_ctl -D $PG_DATA -l $SERVER_LOG start -w -t 30" || {
    LOG_TAIL=$(tail -30 "$SERVER_LOG" 2>/dev/null)
    fail_with_message "**Server failed to start.**

Server log:
\`\`\`
${LOG_TAIL}
\`\`\`"
}

echo "Server is running."

# ---------------------------------------------------------------------------
# 5. Run test workloads and capture stderr
# ---------------------------------------------------------------------------
echo "=== [run_autograder] Running tests ==="

STATS_DIR=/tmp/lab3_stats
rm -rf "$STATS_DIR"
mkdir -p "$STATS_DIR"

run_psql() {
    local label="$1"
    local sql="$2"
    local stderr_file="$STATS_DIR/${label}.txt"
    local stdout_file="$STATS_DIR/${label}_stdout.txt"
    if [ "$(id -u)" = "0" ]; then
        su - pguser -c "export PATH=$PG_INSTALL/bin:\$PATH && psql -d postgres -c \"$sql\"" > "$stdout_file" 2> "$stderr_file"
    else
        psql -d postgres -c "$sql" > "$stdout_file" 2> "$stderr_file"
    fi
    local rc=$?
    echo "  Test $label: exit=$rc, stderr_lines=$(wc -l < "$stderr_file")"
    return $rc
}

# --- Setup: create table and insert test data ---
run_psql "setup" "
DROP TABLE IF EXISTS t_lab3;
CREATE TABLE t_lab3(id int, name text);
INSERT INTO t_lab3 VALUES (1, 'a'), (2, 'b'), (3, 'c'), (4, 'd'),
                          (5, 'e'), (6, 'f'), (7, 'g'), (8, 'h'),
                          (9, 'i'), (10, 'j');
" || true

# --- Test A: INSERT with logging ON ---
# Insert odd values: 11, 13, 15 should log; 12, 14, 16 should not
run_psql "insert_on" "
SET dml_lab.enable_logging = on;
INSERT INTO t_lab3 VALUES (11, 'k');
INSERT INTO t_lab3 VALUES (12, 'l');
INSERT INTO t_lab3 VALUES (13, 'm');
INSERT INTO t_lab3 VALUES (14, 'n');
INSERT INTO t_lab3 VALUES (15, 'o');
INSERT INTO t_lab3 VALUES (16, 'p');
" || true

# --- Test B: INSERT with logging OFF (nothing should log) ---
run_psql "insert_off" "
SET dml_lab.enable_logging = off;
INSERT INTO t_lab3 VALUES (17, 'q');
INSERT INTO t_lab3 VALUES (18, 'r');
" || true

# --- Test C: DELETE with logging ON ---
# Delete even values: 2, 4 should log; 1, 3 should not
run_psql "delete_on" "
SET dml_lab.enable_logging = on;
DELETE FROM t_lab3 WHERE id = 2;
DELETE FROM t_lab3 WHERE id = 1;
DELETE FROM t_lab3 WHERE id = 4;
DELETE FROM t_lab3 WHERE id = 3;
" || true

# --- Test D: DELETE with logging OFF (nothing should log) ---
run_psql "delete_off" "
SET dml_lab.enable_logging = off;
DELETE FROM t_lab3 WHERE id = 5;
DELETE FROM t_lab3 WHERE id = 6;
" || true

# --- Test E: UPDATE with logging ON ---
# Update where old or new value is divisible by 3 should log
run_psql "update_on" "
SET dml_lab.enable_logging = on;
UPDATE t_lab3 SET id = 100 WHERE id = 9;
UPDATE t_lab3 SET id = 200 WHERE id = 7;
UPDATE t_lab3 SET id = 300 WHERE id = 8;
UPDATE t_lab3 SET id = 21 WHERE id = 10;
" || true

# --- Test F: UPDATE with logging OFF (nothing should log) ---
run_psql "update_off" "
SET dml_lab.enable_logging = off;
UPDATE t_lab3 SET id = 999 WHERE id = 100;
" || true

# --- Test G: Mixed workload ---
run_psql "mixed" "
SET dml_lab.enable_logging = on;
INSERT INTO t_lab3 VALUES (33, 'mix1');
INSERT INTO t_lab3 VALUES (44, 'mix2');
DELETE FROM t_lab3 WHERE id = 44;
UPDATE t_lab3 SET id = 66 WHERE id = 33;
" || true

# ---------------------------------------------------------------------------
# 6. Stop server and grade
# ---------------------------------------------------------------------------
echo "=== [run_autograder] Stopping server ==="
run_pg "pg_ctl -D $PG_DATA stop -m fast" || true

echo "=== [run_autograder] Grading ==="
python3 "$SRC_DIR/grade.py" --stats-dir "$STATS_DIR"
